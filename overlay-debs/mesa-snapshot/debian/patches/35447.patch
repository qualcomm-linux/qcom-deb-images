From b2832bb2c262e6f4fdebbf857076db4cf4b9a6ad Mon Sep 17 00:00:00 2001
From: Rob Clark <rob.clark@oss.qualcomm.com>
Date: Sat, 7 Jun 2025 08:24:18 -0700
Subject: [PATCH 1/2] freedreno: Remove obsolete comment

We do used CACHED_COHERENT in some cases.  We don't used
cached-incoherent, so nothing more to do.

Signed-off-by: Rob Clark <rob.clark@oss.qualcomm.com>
---
 src/gallium/drivers/freedreno/freedreno_resource.c | 5 -----
 1 file changed, 5 deletions(-)

diff --git a/src/gallium/drivers/freedreno/freedreno_resource.c b/src/gallium/drivers/freedreno/freedreno_resource.c
index e28ae81fe1bbb..95777b5ba9a83 100644
--- a/src/gallium/drivers/freedreno/freedreno_resource.c
+++ b/src/gallium/drivers/freedreno/freedreno_resource.c
@@ -197,11 +197,6 @@ realloc_bo(struct fd_resource *rsc, uint32_t size)
            FD_BO_CACHED_COHERENT) |
       COND(prsc->bind & PIPE_BIND_SHARED, FD_BO_SHARED) |
       COND(prsc->bind & PIPE_BIND_SCANOUT, FD_BO_SCANOUT);
-   /* TODO other flags? */
-
-   /* if we start using things other than write-combine,
-    * be sure to check for PIPE_RESOURCE_FLAG_MAP_COHERENT
-    */
 
    if (rsc->bo)
       fd_bo_del(rsc->bo);
-- 
